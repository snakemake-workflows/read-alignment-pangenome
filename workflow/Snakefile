from snakemake.utils import min_version

min_version("9.12.0")


# load configuration
# -----------------------------------------------------
configfile: "config/config.yaml"


inputflags:
    access.sequential,


# Allow users to fix the underlying OS via singularity.
container: "docker://continuumio/miniconda3"


# load helpers first
# -----------------------------------------------------
include: "rules/common.smk"


# config-driven pathvars for candidate final BAM stages
# -----------------------------------------------------
pathvars:
    results_bqsr=branch(bqsr_is_final(), then=final_bam_path, otherwise="results/recal"),
    results_consensus=branch(
        consensus_is_final(), then=final_bam_path, otherwise="results/consensus"
    ),
    results_trimmed=branch(
        trimmed_is_final(), then=final_bam_path, otherwise="results/trimmed"
    ),
    results_dedup=branch(
        dedup_is_final(), then=final_bam_path, otherwise="results/dedup"
    ),
    results_mapped_bwa=branch(
        bwa_mapping_is_final(), then=final_bam_path, otherwise="results/mapped/bwa"
    ),
    results_mapped_vg=branch(
        vg_mapping_is_final(), then=final_bam_path, otherwise="results/mapped/vg"
    ),


# load rules
# -----------------------------------------------------
include: "rules/utils.smk"
include: "rules/ref.smk"
include: "rules/trimming.smk"
include: "rules/mapping.smk"
include: "rules/primers.smk"


# optional messages, log and error handling
# -----------------------------------------------------
onstart:
    print("\n--- Analysis started ---\n")


onsuccess:
    print("\n--- Workflow finished! ---\n")


onerror:
    print("\n--- An error occurred! ---\n")


rule all:
    default_target: True
    input:
        expand(f"{final_bam_path}/{{sample}}.bam", sample=list(samples.index)),
