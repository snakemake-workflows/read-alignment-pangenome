# Scope: pangenome download → trimming → mapping → postprocessing → final recalibrated BAM.
# Final outputs:
#   results/recal/{sample}.bam
#   results/recal/{sample}.bai
# Variant calling (BCF/VCF), annotation, filtering, tables, etc. are intentionally out of scope.

from snakemake.utils import min_version

min_version("9.1.0")


# prevent {sample} from swallowing suffixes like ".sorted"
wildcard_constraints:
    sample=r"[^\.\/]+",


# load configuration
# -----------------------------------------------------
configfile: "config/config.yaml"


# load rules
# -----------------------------------------------------
include: "rules/common.smk"
include: "rules/utils.smk"
include: "rules/ref.smk"
include: "rules/trimming.smk"
include: "rules/mapping.smk"
include: "rules/primers.smk"


# optional messages, log and error handling
# -----------------------------------------------------
onstart:
    print("\n--- Analysis started ---\n")


onsuccess:
    print("\n--- Workflow finished! ---\n")


onerror:
    print("\n--- An error occurred! ---\n")


# targets (final BAM + BAI)
# -----------------------------------------------------
rule only_alignment:
    input:
        expand("results/recal/{sample}.bam", sample=list(samples.index)),
        expand("results/recal/{sample}.bai", sample=list(samples.index)),


rule all:
    input:
        rules.only_alignment.input,
    default_target: True
